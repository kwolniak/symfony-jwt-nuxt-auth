# =============================================================================
# Docker Compose / Application Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_in_production

# Symfony DATABASE_URL — uses the Docker service name "postgres"
DATABASE_URL=postgresql://app:change_me_in_production@postgres:5432/app?serverVersion=16&charset=utf8

# -----------------------------------------------------------------------------
# JWT (lexik/jwt-authentication-bundle)
# Generate keys inside the container:
#   docker compose exec php php bin/console lexik:jwt:generate-keypair
# Then paste the base64-encoded key contents here, or use file paths.
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_in_production

# -----------------------------------------------------------------------------
# Google OAuth (knpuniversity/oauth2-client-bundle)
# Create credentials at: https://console.cloud.google.com/apis/credentials
#
# IMPORTANT: Google rejects non-public TLDs (.test, .local, etc.).
# Use localhost for local development — Google accepts loopback addresses.
#
# In Google Cloud Console set:
#   Authorized JavaScript origins:  http://localhost
#   Authorized redirect URIs:       http://localhost/connect/google/check
#
# Nginx routes "localhost" to the first server block (sfl-api.test = Symfony),
# so http://localhost/connect/google/check reaches Symfony without any extra config.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# URLs
# sfl-api.test → Symfony backend (via Nginx, port 80)
# sfl.test     → Nuxt frontend (via Nginx → Node :3000)
#
# APP_URL must be http://localhost for Google OAuth to work locally.
# Symfony uses APP_URL to build the redirect_uri sent to Google.
# -----------------------------------------------------------------------------
APP_URL=http://localhost
NUXT_URL=http://sfl.test

# Nuxt server routes call Symfony via internal Docker network (not external domain)
NUXT_API_BASE_URL=http://nginx

# -----------------------------------------------------------------------------
# CORS (nelmio/cors-bundle) — regex matched against Origin header
# -----------------------------------------------------------------------------
CORS_ALLOW_ORIGIN=^https?://sfl\.test$
